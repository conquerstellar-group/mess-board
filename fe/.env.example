# Domain of the be service, used by the browser to connect via WebSocket.
# e.g. https://api.example.com
# Leave empty to use the same origin as the fe page (only works if fe and be
# share a domain, e.g. behind a single reverse proxy).
#
# NOTE: this is a build-time arg (baked into the image via Dockerfile ARG),
# not a runtime env var. Whenever you change it, rebuild the image:
#   docker compose build --no-cache frontend && docker compose up -d frontend
API_HOST=
